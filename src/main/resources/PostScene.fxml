<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="PostController"
      spacing="15"
      style="-fx-padding: 20;">

    <Label text="Inferior"
           style="-fx-text-fill: red; -fx-font-size: 50px; -fx-font-weight: bold;"
           maxWidth="Infinity"/>

    <Separator/>

    <HBox spacing="15">
        <VBox spacing="20" prefWidth="200">
            <Button text="Profile"
            onAction="#profile"/>
            <Button text="Back"
                    onAction="#back"/>
        </VBox>
        <Separator orientation="VERTICAL"
                   prefHeight="430"/>

        <ScrollPane fitToWidth="true"
                    prefWidth="520"
                    prefHeight="430">
            <VBox fx:id="postFeedBox"
                  spacing="25"
                  style="-fx-padding: 10;">
            </VBox>
        </ScrollPane>
    </HBox>
</VBox>
